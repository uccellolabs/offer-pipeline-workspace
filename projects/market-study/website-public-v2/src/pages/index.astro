---
import BaseLayout from '../layouts/BaseLayout.astro';

const doors = [
  {
    key: 'clarity',
    label: 'Done For You',
    title: 'Offer Clarity',
    tagline: 'Tu reçois un livrable clé-en-main : offre cadrée, pitch deck, templates et 50 prospects qualifiés en 48-72h.',
    forWho: 'Consultants et freelances 1-3 ans d\'activité',
    price: '890',
    priceSuffix: '€ HT',
    priceNote: 'à partir de',
    href: '/offer-clarity/',
    features: [
      'Offre cadrée + persona acheteur',
      'Pitch deck HTML 12 slides',
      'Templates LinkedIn + email',
      'Liste 30-80 prospects qualifiés CSV',
      'Livraison en 48-72h',
    ],
  },
  {
    key: 'solo',
    label: 'Do It Yourself · Solo',
    title: 'Pipeline Solo',
    tagline: 'On installe le pipeline IA propriétaire sur ta machine. Opérationnel en 5-10 jours, à toi pour toujours.',
    forWho: 'Consultants seniors et freelances experts IA',
    price: '1 990',
    priceSuffix: '€ HT',
    priceNote: 'à partir de',
    href: '/pipeline-solo/',
    features: [
      'Installation pipeline + 14 skills',
      'Configuration templates',
      'Personnalisation terminologie (Pro)',
      '1 connecteur léger inclus (Pro)',
      'Formation 2h + support 30-60 jours',
    ],
  },
  {
    key: 'studio',
    label: 'Do It Yourself · Studio',
    title: 'Pipeline Studio',
    tagline: 'Setup pipeline souverain dans votre cabinet, connecteurs CRM, formation équipe, en 6-10 semaines.',
    forWho: 'Cabinets de conseil et agences 5-30 consultants',
    price: '6 990',
    priceSuffix: '€ HT',
    priceNote: 'à partir de',
    href: '/pipeline-studio/',
    features: [
      'Pipeline installé en environnement cabinet',
      '1-2 connecteurs CRM inclus',
      'Adaptation terminologie cabinet',
      'Formation 5-10 consultants',
      'Support 60-90 jours + revues',
    ],
  },
];
---

<BaseLayout
  title="Offer Pipeline · Le pipeline IA de création d'offres B2B"
  description="Le pipeline IA propriétaire de création d'offres B2B, disponible en livrable clé-en-main, en install sur ta machine, ou en stack interne pour cabinet. Trois portes, un même backend éprouvé."
  current="home"
>
  <section class="hero">
    <div class="container hero__inner">
      <span class="eyebrow" style="color: var(--color-secondary);">Offer Pipeline · Édité par Uccello Labs</span>
      <h1>Le pipeline IA de création d'offres B2B<br/>en livrable, en install, ou en stack interne.</h1>
      <p class="lead">
        Choisis ta porte. Trois produits, un même backend éprouvé en production sur la création
        d'offres commerciales B2B. Pas de SaaS, pas d'abonnement d'usage. Tu utilises, tu factures.
      </p>
      <div class="hero__ctas">
        <a href="#gamme" class="btn btn--inverse btn--lg">Découvrir la gamme</a>
        <a href="/contact/" class="btn btn--ghost btn--lg" style="color:#fff; border:1px solid rgba(255,255,255,0.25);">Réserver un appel</a>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <div class="stats">
        <div class="stat">
          <div class="stat__number">3</div>
          <div class="stat__label">Portes d'entrée<br/>selon ton profil</div>
        </div>
        <div class="stat">
          <div class="stat__number">14</div>
          <div class="stat__label">Skills IA<br/>dans le pipeline</div>
        </div>
        <div class="stat">
          <div class="stat__number">2 ans</div>
          <div class="stat__label">De raffinage<br/>en production interne</div>
        </div>
        <div class="stat">
          <div class="stat__number">100 %</div>
          <div class="stat__label">Souverain<br/>aucun SaaS, install client</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="gamme">
    <div class="container">
      <div style="max-width: 56ch; margin-bottom: var(--space-12);">
        <span class="eyebrow">La gamme</span>
        <h2>Trois portes, un même backend.</h2>
        <p class="lead">
          Tu n'achètes pas la même chose selon où tu es.<br/>
          Un freelance qui veut un livrable n'achète pas la même chose qu'un consultant senior
          qui veut son outil, ni qu'un cabinet qui veut une stack interne.
        </p>
      </div>

      <div class="grid grid--3">
        {doors.map((door) => (
          <article class={`door door--${door.key}`}>
            <span class="door__label">{door.label}</span>
            <h3 class="door__title">{door.title}</h3>
            <p class="door__tagline">{door.tagline}</p>
            <p style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: var(--space-5);">
              <strong style="color: var(--color-text);">Pour qui :</strong> {door.forWho}
            </p>
            <div>
              <span style="font-size: 0.8rem; color: var(--color-text-muted);">{door.priceNote}</span>
              <div>
                <span class="door__price">{door.price}</span>
                <span class="door__price-suffix">{door.priceSuffix}</span>
              </div>
            </div>
            <ul class="door__features">
              {door.features.map((f) => <li>{f}</li>)}
            </ul>
            <a href={door.href} class="btn btn--primary door__cta">Voir {door.title} →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container">
      <div class="split">
        <div>
          <span class="eyebrow">Pourquoi 3 portes</span>
          <h2 style="color:#fff;">Le même backend.<br/>Trois manières de l'utiliser.</h2>
          <p class="lead" style="color: rgba(255,255,255,0.78);">
            Le pipeline offer-pipeline est un asset propriétaire (skills + agents Claude),
            éprouvé en production interne sur la création d'offres B2B. La gamme expose trois
            façons d'y accéder, selon ton profil et ton besoin.
          </p>
        </div>
        <div>
          <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap: var(--space-5);">
            <li style="display:flex; gap: var(--space-4); align-items:flex-start;">
              <span style="flex-shrink:0; width:32px; height:32px; background: linear-gradient(135deg, #1D4ED8, #3B82F6); border-radius: 8px; display:flex; align-items:center; justify-content:center; color:#fff; font-weight:700; font-family: var(--font-display);">1</span>
              <div>
                <strong style="color:#fff; display:block; margin-bottom: var(--space-1);">Tu veux le résultat livré.</strong>
                <span style="color: rgba(255,255,255,0.72); font-size: 0.95rem;">Offer Clarity. Tu donnes le brief, je livre offre + supports + prospects en 48-72h.</span>
              </div>
            </li>
            <li style="display:flex; gap: var(--space-4); align-items:flex-start;">
              <span style="flex-shrink:0; width:32px; height:32px; background: linear-gradient(135deg, #0EA5E9, #06B6D4); border-radius: 8px; display:flex; align-items:center; justify-content:center; color:#fff; font-weight:700; font-family: var(--font-display);">2</span>
              <div>
                <strong style="color:#fff; display:block; margin-bottom: var(--space-1);">Tu veux ton propre outil.</strong>
                <span style="color: rgba(255,255,255,0.72); font-size: 0.95rem;">Pipeline Solo. J'installe le pipeline sur ta machine. Tu repars autonome avec un setup pro.</span>
              </div>
            </li>
            <li style="display:flex; gap: var(--space-4); align-items:flex-start;">
              <span style="flex-shrink:0; width:32px; height:32px; background: linear-gradient(135deg, #1E3A8A, #1D4ED8); border-radius: 8px; display:flex; align-items:center; justify-content:center; color:#fff; font-weight:700; font-family: var(--font-display);">3</span>
              <div>
                <strong style="color:#fff; display:block; margin-bottom: var(--space-1);">Tu veux une stack interne.</strong>
                <span style="color: rgba(255,255,255,0.72); font-size: 0.95rem;">Pipeline Studio. Setup en cabinet, connecteurs CRM, formation équipe, souverain.</span>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div style="max-width: 56ch; margin: 0 auto var(--space-12); text-align: center;">
        <span class="eyebrow">Comparer en 30 secondes</span>
        <h2>Quelle porte pour toi ?</h2>
      </div>

      <div class="table-wrap">
        <table class="compare">
          <thead>
            <tr>
              <th></th>
              <th>Offer Clarity</th>
              <th>Pipeline Solo</th>
              <th>Pipeline Studio</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th>Pour qui</th>
              <td>Freelance / consultant 1-3 ans</td>
              <td>Consultant senior power user IA</td>
              <td>Cabinet 5-30 consultants</td>
            </tr>
            <tr>
              <th>Tu reçois</th>
              <td>Un livrable</td>
              <td>L'install sur ta machine</td>
              <td>Une stack interne + intégrations</td>
            </tr>
            <tr>
              <th>Délai</th>
              <td>48-72h</td>
              <td>5-10 jours</td>
              <td>6-10 semaines</td>
            </tr>
            <tr>
              <th>Prix</th>
              <td><strong>890-1 490 €</strong></td>
              <td><strong>1 990-2 990 €</strong></td>
              <td><strong>6 990-9 990 €</strong> + custom</td>
            </tr>
            <tr>
              <th>Modèle</th>
              <td>Forfait one-shot</td>
              <td>Setup + support optionnel</td>
              <td>Setup + custom + maintenance optionnelle</td>
            </tr>
            <tr>
              <th>Cycle de vente</th>
              <td>3-14 jours</td>
              <td>14-30 jours</td>
              <td>60-180 jours</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container container--narrow">
      <span class="eyebrow text-center" style="display:block; text-align:center;">Questions fréquentes</span>
      <h2 class="text-center mb-8">Ce qu'on me demande le plus.</h2>

      <details>
        <summary>C'est un SaaS ? Je dois m'abonner ?</summary>
        <p>
          Non. Aucun produit de la gamme n'est un SaaS. Offer Clarity est un livrable one-shot.
          Pipeline Solo et Pipeline Studio sont installés directement sur ta machine ou ton infrastructure.
          Tu restes propriétaire et autonome. Le contrat de support annuel (optionnel) couvre les
          mises à jour et le dépannage, mais le pipeline tourne sans.
        </p>
      </details>

      <details>
        <summary>Et si Anthropic change ses prix ou ses CGU ?</summary>
        <p>
          Le pipeline est conçu pour évoluer. Les skills sont modulaires et documentés. Tu gardes
          ton install si l'API change. Le contrat de support optionnel couvre la migration. Sans
          contrat, tu as la documentation pour t'adapter toi-même.
        </p>
      </details>

      <details>
        <summary>Mes données clients sont stockées où ?</summary>
        <p>
          Pour Pipeline Solo et Studio, tout est sur ton infrastructure. L'API Anthropic est
          appelée pour la génération mais aucune donnée client n'est stockée chez Uccello.
          RGPD ok, audit possible.
        </p>
      </details>

      <details>
        <summary>Je peux essayer avant de m'engager ?</summary>
        <p>
          Une session de découverte de 30 à 60 minutes est offerte sur les 3 portes. Sans engagement.
          On regarde si ton profil correspond et ce que le service peut produire pour toi.
        </p>
      </details>

      <details>
        <summary>Vous êtes en phase de lancement, ça veut dire quoi ?</summary>
        <p>
          La gamme est ouverte au public depuis mai 2026. Les premières missions de chaque porte
          sont proposées à un tarif pilote en échange d'un témoignage détaillé. C'est l'occasion
          d'avoir le service à prix réduit, en contrepartie d'un retour structuré.
        </p>
      </details>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-banner">
        <span class="eyebrow" style="color: rgba(255,255,255,0.8);">Prêt à passer à l'action ?</span>
        <h2>30 minutes pour cadrer la porte qui te correspond.</h2>
        <p>
          On regarde ton contexte, ton besoin, et je te dis si une des 3 portes peut t'aider.
          Sans pitch, sans pression. Si rien ne colle, je te le dis aussi.
        </p>
        <a href="/contact/" class="btn btn--inverse btn--lg">Réserver un appel</a>
      </div>
    </div>
  </section>
</BaseLayout>
