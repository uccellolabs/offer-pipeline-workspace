---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div>
        <div class="footer__brand">
          <span style="display:inline-flex; align-items:center; justify-content:center; width:32px; height:32px; background: linear-gradient(135deg, #1D4ED8, #0EA5E9); border-radius:6px; color:#fff; font-size:0.85rem; font-weight:700;">OP</span>
          Offer Pipeline
        </div>
        <p style="color: rgba(255,255,255,0.7); max-width: 36ch; font-size: 0.92rem;">
          Le pipeline IA de création d'offres B2B,
          disponible en livrable, en install, ou en stack interne.
        </p>
      </div>

      <div>
        <h5>La gamme</h5>
        <ul>
          <li><a href="/offer-clarity/">Offer Clarity</a></li>
          <li><a href="/pipeline-solo/">Pipeline Solo</a></li>
          <li><a href="/pipeline-studio/">Pipeline Studio</a></li>
        </ul>
      </div>

      <div>
        <h5>Ressources</h5>
        <ul>
          <li><a href="/pour-qui/">Pour qui</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </div>

      <div>
        <h5>Édité par</h5>
        <ul>
          <li><a href="https://uccellolabs.com" target="_blank" rel="noopener noreferrer">Uccello Labs</a></li>
          <li><a href="mailto:jonathan@uccellolabs.com">jonathan@uccellolabs.com</a></li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <span>© {year} Uccello Labs. Tous droits réservés.</span>
      <span>Fait avec attention en France.</span>
    </div>
  </div>
</footer>
