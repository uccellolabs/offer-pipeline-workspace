---
const { current } = Astro.props;
const links = [
  { href: '/offer-clarity/', label: 'Offer Clarity', key: 'clarity' },
  { href: '/pipeline-solo/', label: 'Pipeline Solo', key: 'solo' },
  { href: '/pipeline-studio/', label: 'Pipeline Studio', key: 'studio' },
  { href: '/pour-qui/', label: 'Pour qui', key: 'pour-qui' },
];
---

<nav class="nav" id="site-nav" aria-label="Navigation principale">
  <div class="container">
    <div class="nav__inner">
      <a href="/" class="nav__brand" aria-label="Offer Pipeline, accueil">
        <span class="nav__brand-mark">OP</span>
        <span>Offer Pipeline</span>
      </a>

      <ul class="nav__links">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class="nav__link"
              aria-current={current === link.key ? 'page' : undefined}
            >{link.label}</a>
          </li>
        ))}
      </ul>

      <a href="/contact/" class="btn btn--primary nav__cta">Réserver un appel</a>

      <button class="nav__hamburger" type="button" aria-label="Ouvrir le menu" aria-controls="nav-mobile" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div class="nav__mobile" id="nav-mobile">
    <ul>
      {links.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
      <li><a href="/contact/">Contact</a></li>
    </ul>
    <a href="/contact/" class="btn btn--primary">Réserver un appel</a>
  </div>
</nav>

<script>
  const nav = document.getElementById('site-nav');
  const burger = nav?.querySelector('.nav__hamburger');
  burger?.addEventListener('click', () => {
    const isOpen = nav?.dataset.open === 'true';
    if (nav) nav.dataset.open = isOpen ? 'false' : 'true';
    burger.setAttribute('aria-expanded', String(!isOpen));
    burger.setAttribute('aria-label', isOpen ? 'Ouvrir le menu' : 'Fermer le menu');
  });
</script>
